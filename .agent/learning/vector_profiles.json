{
    "version": 2,
    "profiles": {
        "wiki": {
            "description": "General documentation and project wiki.",
            "manifest": ".agent/learning/vector_knowledge_manifest.json",
            "chroma_data_path": ".agent/learning/vector_wiki_db",
            "child_collection": "wiki_child_v5",
            "parent_collection": "wiki_parent_v5",
            "chroma_host": "127.0.0.1",
            "chroma_port": 8110,
            "batch_size": 1000,
            "embedding_model": "nomic-ai/nomic-embed-text-v1.5",
            "parent_chunk_size": 2000,
            "parent_chunk_overlap": 200,
            "child_chunk_size": 400,
            "child_chunk_overlap": 50
        }
    },
    "default_profile": "wiki"
}