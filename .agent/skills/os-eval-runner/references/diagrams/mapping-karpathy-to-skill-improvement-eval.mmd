graph LR
    subgraph Logical["Logical Role"]
        F_Scaffold["0. Scaffold & Templates<br/>Starter files, deploy once"]
        F_Spec["1. Goal & Boundaries<br/>Defines rules & constraints"]
        F_Engine["2. Execution & Agency<br/>Drives the autonomous loop"]
        F_Target["3. Mutable Target<br/>The artifact being improved"]
        F_Judge["4. Scoring & Gatekeeping<br/>Tests & decides keep/revert"]
        F_Ledger["5. State & Memory<br/>Historical log of attempts"]
    end

    subgraph Karpathy["Karpathy Original"]
        K_Scaffold["(none — hand-write)"]
        K_Spec["program.md"]
        K_Engine["Implied loop<br/>(conceptual only)"]
        K_Target["train.py<br/>(code as target)"]
        K_Judge["prepare.py<br/>(monolithic eval)"]
        K_Ledger["results.tsv"]
    end

    subgraph Ours["Our Implementation"]
        Y_Scaffold["assets/templates/autoresearch/<br/>program.md.template<br/>evals.json.template<br/>results.tsv.template<br/><br/>init_autoresearch.py deploys<br/>rendered copies to experiment dir"]
        Y_Spec["experiment-dir/references/program.md<br/>(deployed from template,<br/>per experiment — not shared)"]
        Y_Engine["Claude Agent<br/>(IS the loop orchestrator)"]
        Y_Target["experiment-dir/mutation-target<br/>(SKILL.md, .py, config, etc.<br/>markdown -> any file type)"]
        Y_Judge["eval_runner.py (metric producer)<br/>+ evaluate.py (loop gate + auto-revert)<br/>+ experiment-dir/evals/evals.json (locked)"]
        Y_Ledger["experiment-dir/evals/results.tsv<br/>(deployed from template,<br/>one per experiment — not shared)<br/>+ evals/.lock.hashes (SHA256 guard)"]
    end

    F_Scaffold -.->|" "| K_Scaffold -.->|"Standardized"| Y_Scaffold
    F_Spec     -.->|" "| K_Spec     -.->|"Per-experiment"| Y_Spec
    F_Engine   -.->|" "| K_Engine   -.->|"Agent IS the loop"| Y_Engine
    F_Target   -.->|" "| K_Target   -.->|"Any file type"| Y_Target
    F_Judge    -.->|" "| K_Judge    -.->|"Split: score / gate"| Y_Judge
    F_Ledger   -.->|" "| K_Ledger   -.->|"Per-experiment + SHA256"| Y_Ledger

