flowchart TD
    Start([User Needs Context]) --> Check{Is RLM\nLedger Built?}

    Check -- No --> Build["Run Distiller (requires Ollama)\nSkill: rlm-curator"]
    Build --> CmdBuild[/"python ./scripts/distiller.py --profile project"/]
    CmdBuild -- "Process all files" --> Cache[(RLM Summary Ledger\nrlm_summary_cache.json\nrlm_tool_cache.json)]

    Check -- Yes --> Audit["Check Coverage\nSkill: rlm-curator"]
    Audit --> CmdAudit[/"python ./scripts/inventory.py --profile project"/]
    CmdAudit -- "Missing Files?" --> Gaps{Gaps Found?}

    Gaps -- Yes --> Patch["Distill Specific File or\nUse Agent Distill (/rlm-factory:distill-agent)"]
    Patch --> CmdPatch[/"python ./scripts/inject_summary.py --profile project --file path"/]
    CmdPatch --> Cache

    Gaps -- No --> Search["Query Cache (offline, O(1))\nSkill: rlm-search"]
    Search --> CmdSearch[/"python ./scripts/query_cache.py --profile project 'term'"/]
    CmdSearch -- "Result: matching summaries + paths" --> Result([Context Retrieved])
