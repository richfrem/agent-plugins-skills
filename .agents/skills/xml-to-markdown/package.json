{
  "name": "oracle-forms-xml-parser",
  "version": "1.0.0",
  "description": "A tool to parse Oracle Forms XML files and extract PL/SQL code",
  "type": "module",
  "main": "scripts/convert-forms-xml-to-markdown.js",
  "scripts": {
    "start": "node scripts/convert-forms-xml-to-markdown.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:elements": "node scripts/tests/utils/runElementTests.js",
    "update-utils": "node scripts/update-utils-references.js",
    "fix-imports": "node scripts/fix-util-imports.js",
    "generate-processors": "node scripts/generateProcessors.js",
    "generate-test-data": "node scripts/generate-test-data.js",
    "remove-xml-declaration": "node scripts/removeXmlDeclaration.js",
    "generate-missing-test-data": "node scripts/generateMissingTestData.js",
    "remove-xml-root-tags": "node scripts/removeXmlRootTags.js",
    "update-test-data-paths": "node scripts/updateTestDataPaths.js",
    "clean-xml-files": "node scripts/cleanXmlFiles.js",
    "check-processors": "node src/scripts/checkProcessors.js",
    "standardize-processors": "node scripts/standardize-processors.js",
    "standardize-naming": "node scripts/standardize-naming.js",
    "standardize-test-data": "node standardize-test-data-folders.js",
    "restore-comments": "node scripts/restore-processor-comments.js",
    "update-test-imports": "node scripts/update-test-imports.js",
    "fix-processor-exports": "node scripts/fix-processor-exports.js",
    "fix-test-imports": "node scripts/fix-test-imports.js",
    "rename-tests": "node scripts/rename-test-files.js",
    "standardize-processor-exports": "node scripts/standardize-processor-exports.js",
    "check-naming": "node scripts/check-processor-naming.js"
  },
  "keywords": [
    "oracle",
    "forms",
    "fmb",
    "mmb",
    "olb",
    "xml",
    "parser",
    "documentation"
  ],
  "author": "Richard Fremmerlid",
  "license": "MIT",
  "dependencies": {
    "@prettier/plugin-xml": "^3.0.0",
    "@xmldom/xmldom": "^0.8.10",
    "brace-expansion": ">=5.0.5",
    "fast-xml-parser": "^5.5.9",
    "glob": "^13.0.6",
    "prettier": "^3.2.5",
    "sax": "^1.4.1",
    "xml2js": "^0.6.2",
    "xpath": "^0.0.32"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "babel-jest": "^30.3.0",
    "chai": "^5.2.0",
    "jest": "^30.3.0"
  },
  "overrides": {
    "brace-expansion": ">=5.0.5",
    "picomatch": ">=4.0.4"
  }
}
