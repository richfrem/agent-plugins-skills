---
config:
  theme: base
---
flowchart TB
 subgraph Legend["ADR-0019: Separation of Concerns"]
        L1["<b style='color:#E6E6FA'>investigate-report</b> = Reusable Analysis (Context + Mining)"]
        L2["<b style='color:#90EE90'>codify-report</b> = Documentation Output"]
  end
 subgraph subGraph0["User Entry Point"]
        P1_Codify@{ label: "Command: <b style='color:#32CD32'>/codify-report</b> [ID]<br><i>(Output: Report-Overview.md)</i>" }
  end
 subgraph Investigate["<b>/investigate-report</b> (Reusable Analysis Module)"]
        direction TB
        subgraph Phase1["Phase 1: Context Initialization"]
            P3_Init@{ label: "Step 1: Initialize Smart Context<br><b style='color:#1E90FF'>cli.py init-context</b> --target [ID] --type report<br>Outputs: ID_context_bundle.md" }
            P3_Review@{ label: "Step 2: Review Context" }
        end
        subgraph Phase2["Phase 2: Recursive Context Spiral"]
            P3_Gap{"Context Complete?"}
            P3_Edit["Add Dependencies<br>━━━━━━━━━━━━━━━━<br>Level 1: XML Source<br>Level 2: Tables/Packages"]
            P3_Rebundle@{ label: "Regenerate Bundle<br><b style='color:#1E90FF'>cli.py manifest bundle</b>" }
        end
        subgraph Phase3["Phase 3: Mining"]
            P3_Mine@{ label: "Step 3: Run Report Miner<br><b style='color:#1E90FF'>report_miner.py</b>" }
            P3_Extract["Extracts:<br>Queries | Data Model | Triggers | Params"]
        end
        subgraph Phase4["Phase 4: Verification"]
            P3_Dep@{ label: "Dependency Check<br><b style='color:#1E90FF'>cli.py dependencies</b>" }
            P3_Check["Context Completeness<br>✓ Source ✓ Queries ✓ DB Deps"]
        end
  end
 subgraph CodifyOutput["<b>/codify-report</b> Output Phase"]
        direction TB
        P4_Fill["Step: Fill Template<br>(REPORT_OVERVIEW_TEMPLATE)"]
        P5_Distill@{ label: "Distill RLM" }
        P5_Inv@{ label: "Rebuild Inventory" }
        P5_Doc["Output: [ID]-Report-Overview.md"]
  end
    P1_Codify --> P3_Init
    P3_Init --> P3_Review --> P3_Gap
    P3_Gap -- "No: Augment" --> P3_Edit --> P3_Rebundle --> P3_Review
    P3_Gap -- "Yes: Ready" --> P3_Mine
    P3_Mine --> P3_Extract --> P3_Dep --> P3_Check

    P3_Check --> P4_Fill
    P4_Fill --> P5_Distill --> P5_Inv --> P5_Doc

    style P1_Codify fill:#90EE90
    style Investigate fill:#E6E6FA
    style P5_Doc fill:#90EE90