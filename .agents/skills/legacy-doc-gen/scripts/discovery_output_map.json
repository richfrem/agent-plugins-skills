{
    "mappings": [
        {
            "type": "form",
            "source_pattern": "legacy-system/oracle-forms/XML/**/*_fmb.xml",
            "doc_target_dir": "legacy-system/oracle-forms-overviews/forms/",
            "doc_naming_convention": "{name}-Overview.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/form-overview-template.md",
            "policy_path": ".agent/rules/form_documentation_policy.md"
        },
        {
            "type": "report",
            "source_pattern": "legacy-system/oracle-forms/Reports/**/*.xml",
            "doc_target_dir": "legacy-system/oracle-forms-overviews/reports/",
            "doc_naming_convention": "{name}-Report-Overview.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/report-overview-template.md",
            "policy_path": ".agent/rules/report_documentation_policy.md"
        },
        {
            "type": "library",
            "source_pattern": "legacy-system/oracle-forms/pll/**/*.txt",
            "doc_target_dir": "legacy-system/oracle-forms-overviews/libraries/",
            "doc_naming_convention": "{name}-Library-Overview.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/library-overview-template.md",
            "policy_path": ".agent/rules/library_documentation_policy.md"
        },
        {
            "type": "menu",
            "source_pattern": "legacy-system/oracle-forms/XML/**/*_mmb.xml",
            "doc_target_dir": "legacy-system/oracle-forms-overviews/menus/",
            "doc_naming_convention": "{name}-Menu-Overview.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/menu-overview-template.md",
            "policy_path": ".agent/rules/menu_documentation_policy.md"
        },
        {
            "type": "business_rule",
            "source_pattern": "NA",
            "doc_target_dir": "legacy-system/business-rules/",
            "doc_naming_convention": "{name}.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/business-rule-template.md",
            "policy_path": ".agent/rules/business_rule_documentation_policy.md"
        },
        {
            "type": "workflow",
            "source_pattern": "NA",
            "doc_target_dir": "legacy-system/business-workflows/",
            "doc_naming_convention": "BW-{id}-{slug}.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/sop-codify-business-workflow-template.md",
            "policy_path": ".agent/rules/business_workflow_documentation_policy.md"
        },
        {
            "type": "db_procedure",
            "source_pattern": "legacy-system/oracle-database/Procedures/**/*.sql",
            "doc_target_dir": "legacy-system/database-overviews/procedures/",
            "doc_naming_convention": "{name}-Procedure-Overview.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/db-procedure-template.md",
            "policy_path": ".agent/rules/database_object_documentation_policy.md"
        },
        {
            "type": "db_function",
            "source_pattern": "legacy-system/oracle-database/Functions/**/*.sql",
            "doc_target_dir": "legacy-system/database-overviews/functions/",
            "doc_naming_convention": "{name}-Function-Overview.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/db-procedure-template.md",
            "policy_path": ".agent/rules/database_object_documentation_policy.md"
        },
        {
            "type": "db_table",
            "source_pattern": "legacy-system/oracle-database/Tables/**/*.sql",
            "doc_target_dir": "legacy-system/database-overviews/tables/",
            "doc_naming_convention": "{name}-Table-Overview.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/db-table-template.md",
            "policy_path": ".agent/rules/database_object_documentation_policy.md"
        },
        {
            "type": "db_view",
            "source_pattern": "legacy-system/oracle-database/Views/**/*.sql",
            "doc_target_dir": "legacy-system/database-overviews/views/",
            "doc_naming_convention": "{name}-View-Overview.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/db-table-template.md",
            "policy_path": ".agent/rules/database_object_documentation_policy.md"
        },
        {
            "type": "db_package",
            "source_pattern": "legacy-system/oracle-database/source/Packages/**/*.sql",
            "doc_target_dir": "legacy-system/database-overviews/packages/",
            "doc_naming_convention": "{name}-Package-Overview.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/db-package-template.md",
            "policy_path": ".agent/rules/database_object_documentation_policy.md"
        },
        {
            "type": "db_type",
            "source_pattern": "legacy-system/oracle-database/Types/**/*.sql",
            "doc_target_dir": "legacy-system/database-overviews/types/",
            "doc_naming_convention": "{name}-Type-Overview.md",
            "template_path": "plugins/legacy system/skills/legacy-doc-gen/assets/templates/db-type-template.md",
            "policy_path": ".agent/rules/database_object_documentation_policy.md"
        }
    ],
    "post_processing": {
        "update_rlm_cache": {
            "command": "python plugins/rlm-factory/scripts/distiller.py --file {doc_path}",
            "description": "Updates RLM summary cache for the documented file"
        },
        "update_vector_db": {
            "command": "python plugins/vector-db/scripts/ingest.py --file {doc_path}",
            "description": "Incrementally updates Vector DB embeddings for the documented file"
        }
    }
}