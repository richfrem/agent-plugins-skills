%% Synchronization Primitives
%% Shows the three coordination patterns: Turn Signal, Fan-Out, Request-Reply

flowchart TB

  subgraph PatA ["Pattern A: Turn Signal (replaces CURRENT_TURN polling)"]
    direction LR
    A1["UPSTREAM\nemits signal.wakeup\nto: LAB"] --> A_BUS[("Bus")]
    A_BUS --> A2["LAB wakes\n(subscribed: signal.wakeup)\nruns eval"]
    A2 --> A3["LAB emits\neval.result\nto: UPSTREAM"]
    A3 --> A_BUS2[("Bus")]
    A_BUS2 --> A4["UPSTREAM wakes\n(subscribed: eval.result)\napplies fix, re-signals LAB"]
    A_NOTE["No polling.\nPush-based.\nLatency = bus write + subscriber check"]
    style A_NOTE fill:#fff9c4,stroke:#f9a825
  end

  subgraph PatB ["Pattern B: Broadcast Fan-Out (N concurrent inner agents)"]
    direction TB
    B1["UPSTREAM emits\ntask.assigned\nto: * (broadcast)\npayload: 3 skill partitions"] --> B_BUS[("Bus")]
    B_BUS --> B2["IA_1 wakes\nclaims partition 1\nvia lock(skill.A)"]
    B_BUS --> B3["IA_2 wakes\nclaims partition 2\nvia lock(skill.B)"]
    B_BUS --> B4["IA_3 wakes\nclaims partition 3\nvia lock(skill.C)"]
    B2 & B3 & B4 --> B5["Each emits\ntask.complete\n(independent)"]
    B5 --> B_BUS2[("Bus")]
    B_BUS2 --> B6["UPSTREAM counts completions\nvia semaphore in os-state.json\nmerges when count == 3"]
    B_NOTE["True parallel execution.\nNo worktree isolation needed.\nSemaphore guards merge gate."]
    style B_NOTE fill:#e8f5e9,stroke:#2e7d32
  end

  subgraph PatC ["Pattern C: Request-Reply (event-native dual-loop)"]
    direction LR
    C1["UPSTREAM emits\ntask.assigned\nto: INNER_AGENT\npayload: {skill, problem}"] --> C_BUS[("Bus")]
    C_BUS --> C2["INNER_AGENT wakes\nexecutes audit\n(context window only)"]
    C2 --> C3["INNER_AGENT emits\ntask.complete\nreply_to: original event id\npayload: {findings}"]
    C3 --> C_BUS2[("Bus")]
    C_BUS2 --> C4["UPSTREAM wakes\nreads findings\napplies fix"]
    C_NOTE["Replaces CLI pipe pattern\nwhen inner agent has bus access.\nCorrelation via reply_to field."]
    style C_NOTE fill:#e3f2fd,stroke:#1565c0
  end

  subgraph PatD ["Deadlock Detection & Recovery"]
    direction LR
    D1["Agent A holds\nlock(skill.X)\ncrashes / times out"] --> D2["kernel.py detects\nlock held > threshold\n(heartbeat check)"]
    D2 --> D3["emits lock.contended\nto: *"]
    D3 --> D4["os-clean-locks wakes\n(subscribed: lock.contended)\nforces unlock(skill.X)\nemits lock.released"]
    D4 --> D5["Waiting agents\nretry acquisition"]
    D_NOTE["Heartbeat: each active agent\nemits agent.heartbeat every N secs.\nSilence = presumed dead."]
    style D_NOTE fill:#fce4ec,stroke:#c62828
  end

  %% Styles
  classDef busNode fill:#fffde7,stroke:#fbc02d,stroke-width:3px
  classDef agentNode fill:#f9f0ff,stroke:#5e35b1,stroke-width:2px
  classDef kernelNode fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px

  class A_BUS,A_BUS2,B_BUS,B_BUS2,C_BUS,C_BUS2 busNode
  class A1,A2,A3,A4,B1,B2,B3,B4,B5,B6,C1,C2,C3,C4 agentNode
  class D1,D2,D3,D4,D5 kernelNode
