config:
  layout: elk
  theme: base
---

%% Pattern 5: Concurrent Event-Driven Multi-Agent Loop
%% Thread Model Overview - agents as OS threads sharing an address space

flowchart TB

  subgraph SharedAddress ["Shared Address Space (Filesystem)"]
    direction TB

    subgraph Kernel ["Kernel Layer"]
      direction LR
      KernelPy["kernel.py\n(Lock + Emit + Signal Broker)"]
      Registry[("agent-registry.json\n(Process Table)")]
      OSState[("os-state.json\n(Semaphore + Lock State)")]
    end

    subgraph Bus ["Event Bus"]
      EventBus[("events.jsonl\n(Shared Message Queue\nAppend-Only)")]
    end

    subgraph Memory ["Shared Memory (L2/L3)"]
      direction LR
      ContextMem["context/memory.md\n(Long-Term Curated)"]
      DatedLogs["context/memory/\nYYYY-MM-DD.md\n(Session Logs)"]
    end

  end

  subgraph Threads ["Agent Threads (Concurrent Claude Sessions)"]
    direction LR

    subgraph T1 ["Thread: UPSTREAM"]
      T1_Stack["Private Stack\n(Context Window)"]
      T1_Role["Role: apply fixes,\ncommit, review"]
      T1_Sub["Subscribed to:\neval.result\ntask.complete\nsignal.wakeup"]
    end

    subgraph T2 ["Thread: LAB"]
      T2_Stack["Private Stack\n(Context Window)"]
      T2_Role["Role: run evals,\nsync skills, test"]
      T2_Sub["Subscribed to:\ntask.assigned\nsignal.wakeup"]
    end

    subgraph T3 ["Thread: INNER_AGENT (ephemeral)"]
      T3_Stack["Private Stack\n(Context Window)"]
      T3_Role["Role: audit skill,\npropose rewrite"]
      T3_Sub["Subscribed to:\ntask.assigned\n(exits on task.complete)"]
    end

  end

  %% Thread -> Kernel interactions
  T1_Stack -- "emit(fix.applied)" --> KernelPy
  T1_Stack -- "emit(signal.wakeup, to=LAB)" --> KernelPy
  T1_Stack -- "lock(skill.A)" --> KernelPy

  T2_Stack -- "emit(eval.result)" --> KernelPy
  T2_Stack -- "emit(agent.ready)" --> KernelPy

  T3_Stack -- "emit(task.complete)" --> KernelPy
  T3_Stack -- "emit(fix.proposed)" --> KernelPy

  %% Kernel -> Bus
  KernelPy -- "validates + appends" --> EventBus
  KernelPy -- "checks registry" --> Registry
  KernelPy -- "atomic os.mkdir()" --> OSState

  %% Bus -> Threads (push notification)
  EventBus -. "event fires\n(subscribed types)" .-> T1_Sub
  EventBus -. "event fires\n(subscribed types)" .-> T2_Sub
  EventBus -. "event fires\n(subscribed types)" .-> T3_Sub

  %% Memory reads/writes
  T1_Stack -- "promote facts" --> ContextMem
  T2_Stack -- "write session log" --> DatedLogs
  KernelPy -- "reads registry" --> Registry

  %% Styles
  classDef thread fill:#f9f0ff,stroke:#5e35b1,stroke-width:2px
  classDef kernel fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
  classDef bus fill:#fffde7,stroke:#fbc02d,stroke-width:3px
  classDef memory fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
  classDef sub fill:#fce4ec,stroke:#880e4f,stroke-width:1px,stroke-dasharray: 4 4

  class T1_Stack,T2_Stack,T3_Stack thread
  class T1_Role,T2_Role,T3_Role thread
  class KernelPy,OSState kernel
  class EventBus bus
  class Registry,ContextMem,DatedLogs memory
  class T1_Sub,T2_Sub,T3_Sub sub
