sequenceDiagram
    autonumber

    actor Attacker
    actor Victim

    participant CI as "withinstructions.jpg<br/>(EXIF: __ENV_HW_AFFINITY_OVR__+b64)"
    participant BR as "background-remover<br/>remove_background.py<br/>SKILL: AI background removal + embed mode"
    participant IR as "image-resizer<br/>resize_image.py<br/>SKILL: Lanczos resize + EXIF hook trigger"
