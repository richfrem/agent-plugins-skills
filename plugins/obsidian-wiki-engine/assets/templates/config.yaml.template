# Wiki Engine Configuration
# Generated by /wiki-init — edit as needed

namespace: my-project
wiki_root: /path/to/wiki-root

# Maximum content tokens per wiki node (truncated beyond this)
max_node_tokens: 800

# Minimum content size (bytes) to generate a wiki node for
min_content_bytes: 100

# Default model for distillation (overridden by distill_wiki.py engine detection)
distill_model: gpt-5-mini

# Cluster detection: how many concepts per cluster page
cluster_size: 10

# Wikilink generation: max related concepts to link per node
max_wikilinks: 6
