graph TD
    %% Nodes - Feature Level (Start)
    Start((\"Start Feature\"))
    Specify[\"fa:fa-file-alt Specify Feature<br>(CLI: spec-kitty specify)\"]
    Gate0{\"fa:fa-user HITL Gate 0<br>USER APPROVES spec.md<br>'Proceed'/'Go'/'Execute'\"}
    Plan[\"fa:fa-map Plan Implementation<br>(CLI: spec-kitty plan)\"]
    Gate1{\"fa:fa-user HITL Gate 1<br>USER APPROVES plan.md<br>'Proceed'/'Go'/'Execute'\"}
    Tasks[\"fa:fa-tasks Generate Tasks<br>(CLI: spec-kitty tasks)\"]
    Gate2{\"fa:fa-user HITL Gate 2<br>USER APPROVES tasks.md+WPs<br>'Proceed'/'Go'/'Execute'\"}

    %% Nodes - WP Level (Loop)
    subgraph WP_Loop[\"WP Execution Loop (Repeated per WP)\"]
        Implement[\"fa:fa-tools Start WP<br>(CLI: spec-kitty implement WP-xx)<br>(Creates: .worktrees/WP-xx)\"]
        Code[\"fa:fa-code Code and Test<br>(Context: Inside Worktree)\"]
        Commit[\"fa:fa-save Git Commit (Local)<br>(git commit -m 'feat...')<br>PUSH branch to origin for safety\"]
        MoveReview[\"fa:fa-arrow-right Move to Review<br>(CLI: spec-kitty agent tasks move-task WP-xx for_review)\"]
        Review[\"fa:fa-glasses Review WP<br>(CLI: spec-kitty review WP-xx)<br>(Moves to 'Done')\"]
    end

    %% Nodes - Feature Level (End)
    subgraph Completion[\"Feature Completion\"]
        SafetySync[\"fa:fa-sync Sync Research Files<br>rsync worktree kitty-specs/ to main<br>BEFORE merge removes worktree\"]
        Accept[\"fa:fa-check-double Accept Feature<br>(CLI: spec-kitty agent feature accept<br>--feature slug --mode local --lenient --json)<br>All WPs must be done, tasks.md checked\"]
        Retro[\"fa:fa-book Retrospective<br>(CLI: /spec-kitty_retrospective)\"]
        Merge[\"fa:fa-magic Spec-Kitty Merge<br>(CLI: spec-kitty merge --feature slug)<br>(Auto-Removes Worktrees)\"]
        End((\"Feature Done\"))
    end

    %% Flow - Planning Phase with HITL Gates
    Start --> Specify
    Specify -->|"STOP: show spec.md to user"| Gate0
    Gate0 -->|"APPROVED"| Plan
    Gate0 -->|"REJECTED: revise"| Specify
    Plan -->|"STOP: show plan.md to user"| Gate1
    Gate1 -->|"APPROVED"| Tasks
    Gate1 -->|"REJECTED: revise"| Plan
    Tasks -->|"STOP: show tasks.md to user"| Gate2
    Gate2 -->|"APPROVED"| Implement
    Gate2 -->|"REJECTED: revise"| Tasks

    %% Loop Logic
    Implement --> Code
    Code --> Commit
    Commit --> MoveReview
    MoveReview --> Review

    %% Iterate or Finish
    Review -->|"Next WP?"| Implement
    Review -->|"All WPs Done?"| SafetySync

    %% Finalization
    SafetySync --> Accept
    Accept --> Retro
    Retro --> Merge
    Merge --> End

    %% Styles
    classDef feature fill:#e3f2fd,stroke:#1565c0,stroke-width:2px;
    classDef gate fill:#ffebee,stroke:#c62828,stroke-width:3px,color:#b71c1c;
    classDef wp fill:#fff3e0,stroke:#ef6c00,stroke-width:2px;
    classDef done fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px;
    classDef safety fill:#fce4ec,stroke:#ad1457,stroke-width:2px;

    class Specify,Plan,Tasks feature;
    class Gate0,Gate1,Gate2 gate;
    class Implement,Code,Commit,MoveReview,Review wp;
    class SafetySync safety;
    class Accept,Retro,Merge,End done;
