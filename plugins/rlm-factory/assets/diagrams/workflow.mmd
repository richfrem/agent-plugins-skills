flowchart TD
    Start([User Needs Context]) --> Check{Is RLM<BR>Ledger Built?}

    Check -- No --> Build["Run Distiller Swarm<BR>Skill: rlm-curator"]
    Build --> CmdBuild[/"python ./scripts/swarm_run.py --engine copilot ..."/]
    CmdBuild -- "Process all files" --> Cache[(RLM Summary Ledger<BR>rlm_summary_cache/*.md<BR>rlm_tool_cache/*.md)]

    Check -- Yes --> Audit["Check Coverage<BR>Skill: rlm-curator"]
    Audit --> CmdAudit[/"python ./scripts/inventory.py --profile project"/]
    CmdAudit -- "Missing Files?" --> Gaps{Gaps Found?}

    Gaps -- Yes --> Patch["Distill Specific File or<BR>Use Agent Distill (/rlm-factory:distill-agent)"]
    Patch --> CmdPatch[/"python ./scripts/inject_summary.py --profile project --file path"/]
    CmdPatch --> Cache

    Gaps -- No --> Search["Query Cache (offline, O(1))<BR>Skill: rlm-search"]
    Search --> CmdSearch[/"python ./scripts/query_cache.py --profile project 'term'"/]
    CmdSearch -- "Result: matching summaries + paths" --> Result([Context Retrieved])
