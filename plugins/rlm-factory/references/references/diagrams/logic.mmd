flowchart TD
    subgraph Initialization ["Step 1: Install and Configure"]
        Req["requirements.txt\n(ruamel, requests, etc.)"]
        Config["rlm_config.py\nProfile: project | tools\nDefines scan paths and cache locations"]
        Req --> Install{{"pip install -r requirements.txt"}}
        Install --> Venv[(Python Env)]
        Config --> Venv
        note1["PREREQUISITE: Ollama running for distillation\n(query_cache.py works offline -- no Ollama needed)"]
        note1 -.- Config
    end

    subgraph Distillation ["Step 2: Build the RLM Summary Ledger (rlm-curator skill)"]
        Venv --> Distiller["distiller.py --profile project"]
        Distiller -- "Scan target directories" --> Sources["Markdown / Python / YAML files"]
        Distiller -- "POST /api/generate + rlm_summarize_general.md prompt" --> Ollama((Ollama API\ngranite3.2:8b))
        Ollama -- "1-sentence dense summary" --> Distiller
        Distiller -- "Incremental write (fcntl.flock)" --> Cache[("rlm_summary_cache.json\nrlm_tool_cache.json")]
        Inject["inject_summary.py\n(agent gap-fill path)"] -- "Single-file inject" --> Cache
    end

    subgraph Consumption ["Step 3: Query the Ledger (rlm-search skill)"]
        Cache --> Query["query_cache.py --profile project 'keyword'\nO(1) substring search -- no Ollama"]
        Cache --> Inventory["inventory.py --profile project\nCoverage audit"]
        Cache --> Cleanup["cleanup_cache.py\nRemove stale/orphan entries"]
        Query -- "Matching summaries + file paths" --> User
        Inventory -- "Coverage %" --> User
    end
