%%{init: {'theme': 'default', 'flowchart': {'curve': 'linear'}}}%%
flowchart TD
    START([os-eval-backport triggered<BR>via SKILL.md routing]) --> P0

    subgraph P0["Phase 0 — Intake"]
        P0A[Q1: Lab repo path<BR>e.g. ~/Projects/test-<plugin>-eval] --> P0B
        P0B[Q2: Master plugin path<BR>e.g. <Master Repository>/<plugin>] --> P0C
        P0C["Q3: Baseline commit SHA<BR>git log --oneline in lab repo<BR>look for 'baseline:' commit"] --> P0D
        P0D["Confirm block:<BR>Lab repo: /path/to/test-repo<BR>Master plugin: <Master Repository>/<plugin><BR>Baseline commit: <sha>"]
    end

    P0D --> P1

    subgraph P1["Phase 1 — Read Run Log & Self-Assessment"]
        P1A["ls <lab-repo>/temp/logs/<BR>ls <lab-repo>/temp/retrospectives/<BR>e.g. survey_YYYYMMDD_HHMM_<skill>.md"] --> P1B
        P1B["Note: final score vs baseline<BR>KEEP vs DISCARD count<BR>errors / workarounds<BR>agent's next-step recommendation"]
    end

    P1B --> P2

    subgraph P2["Phase 2 — Get Full Diff"]
        P2A["git log --oneline <baseline>..HEAD<BR>git diff <baseline> HEAD --name-only<BR>git diff <baseline> HEAD"] --> P2B
        P2B["Key files to watch:<BR>skills/<skill>/SKILL.md<BR>skills/<skill>/evals/evals.json<BR>references/copilot_proposer_prompt.md<BR>.agents/skills/os-eval-runner/ (if patched)<BR>scripts/*.py"] --> P2C
        P2C[Annotate each: what changed / why from log / generalizes to master?]
    end

    P2C --> P3

    subgraph P3["Phase 3 — Structured Assessment"]
        P3A["Build verdict table:<BR>File | Change summary | Verdict | Reason<BR><BR>ACCEPT — apply verbatim<BR>ADAPT — apply with modifications<BR>REJECT — do not apply<BR>REVIEW — needs closer inspection"] --> P3B
        P3B{User approves table?}
        P3B -- No, revise --> P3A
        P3B -- Yes --> P4
    end

    subgraph P4["Phase 4 — Apply Approved Changes"]
        P4A["1. Read current master file<BR>   <Master Repository>/<plugin>/skills/<skill>/SKILL.md"] --> P4B
        P4B["2. Targeted edits only<BR>   never paste full file contents<BR>   master may have diverged from lab copy"] --> P4C
        P4C[3. Verify result] --> P4D
        P4D["4. git add + commit<BR>   backport(<plugin>): <summary>"]
    end

    P4 --> P5

    subgraph P5["Phase 5 — Interrogate the Lab Agent"]
        P5A["Always ask (relay to user or ask in same session):<BR>1. Which steps in eval-instructions.md were unclear / caused improvisation?<BR>2. Paste full evolved references/copilot_proposer_prompt.md<BR>3. Did Step A3 trace scan work? Useful or too noisy?"] --> P5B
        P5B{Loop stalled<BR>3+ DISCARDs?}
        P5B -- Yes --> P5C["4. What did web research or Copilot brainstorm find?<BR>5. What bridge words discovered?<BR>   → Add to Trap Warning in copilot_proposer_prompt.md"]
        P5B -- No --> P5D
        P5C --> P5D
        P5D{Environment reset<BR>mid-run?}
        P5D -- Yes --> P5E["6. Cold Start protocol sufficient?<BR>   (restore .lock.hashes from git baseline)"]
        P5D -- No --> P5F
        P5E --> P5F
        P5F[Incorporate findings → eval-instructions.template.md<BR>copilot_proposer_prompt.md.template<BR>os-eval-runner/SKILL.md]
    end

    P5F --> P5b

    subgraph P5b["Phase 5b — Close the Loop"]
        P5bA[Report: which master files updated] --> P5bB
        P5bB[Report: which changes rejected + why] --> P5bC
        P5bC["Suggest follow-up:<BR>• next eval round<BR>• evals.json coverage gaps<BR>• test fixture improvements<BR>• copilot_proposer_prompt.md refinements"]
    end

    P5bC --> P6

    subgraph P6["Phase 6 — Capture Learnings (Mandatory)"]
        P6A{"OS initialized?<BR>ls context/kernel.py"} -- Present --> P6B
        P6A -- Absent --> P6C
        P6B["Delegate to os-memory-manager skill:<BR>write context/memory/YYYY-MM-DD.md<BR>Fields: skill, baseline→final score,<BR>iterations, backported, rejected, snags"]
        P6C["Write directly:<BR>mkdir -p context/memory<BR>context/memory/YYYY-MM-DD.md"]
        P6B --> P6D
        P6C --> P6D
        P6D{"Non-obvious filter:<BR>would future agent get burned<BR>without this?"}
        P6D -- Passes filter --> P6E
        P6D -- "Routine / self-evident<BR>/ already in memory" --> P6F
        P6E["Write memory/feedback_eval_<skill>_<topic>.md<BR>Update MEMORY.md index<BR>Types: scoring footgun / snag that blocked /<BR>non-obvious architecture / reusable ADAPT pattern"]
        P6E --> P6G
        P6F[Skip — no memory entry needed] --> P6I
        P6G{"OS present?"}
        P6G -- Yes --> P6H["os-memory-manager: promote to<BR>context/memory.md with dedup ID"]
        P6G -- No --> P6I
        P6H --> P6I
        P6I([Done])
    end

    subgraph MAPPING["Master Source Mapping Reference"]
        MAP1["Lab: <plugin>/skills/<skill>/SKILL.md<BR>→ Master: <Master Repository>/<plugin>/skills/<skill>/SKILL.md"]
        MAP2["Lab: <plugin>/skills/<skill>/evals/evals.json<BR>→ Master: <Master Repository>/<plugin>/skills/<skill>/evals/evals.json"]
        MAP3["Lab: .agents/skills/os-eval-runner/<BR>→ Master: <Master Repository>/agent-agentic-os/skills/os-eval-runner/"]
        MAP4["Lab: references/copilot_proposer_prompt.md<BR>→ Contribute to: <Master Repository>/copilot-cli/skills/copilot-cli-agent/references/"]
    end

    style P0 fill:#e8f4f8,stroke:#4a9eca
    style P1 fill:#f0f8e8,stroke:#5a9e4a
    style P2 fill:#f8f4e8,stroke:#ca9a4a
    style P3 fill:#f8e8e8,stroke:#ca4a4a
    style P4 fill:#e8e8f8,stroke:#4a4aca
    style P5 fill:#f8e8f8,stroke:#9a4aca
    style P5b fill:#e8f8f8,stroke:#4acaca
    style P6 fill:#f8f8e8,stroke:#9a9a4a
    style MAPPING fill:#f4f4f4,stroke:#999
