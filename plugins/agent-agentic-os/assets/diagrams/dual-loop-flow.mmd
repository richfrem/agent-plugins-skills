flowchart TB
    classDef outerNode fill:#f3e8ff,stroke:#d8b4fe,stroke-width:2px,color:#581c87
    classDef innerNode fill:#dbeafe,stroke:#93c5fd,stroke-width:2px,color:#1e3a8a
    classDef evalNode fill:#fef3c7,stroke:#fcd34d,stroke-width:1px,color:#78350f
    classDef memNode fill:#dcfce7,stroke:#86efac,stroke-width:1px,color:#14532d
    classDef gateNode fill:#fee2e2,stroke:#fca5a5,stroke-width:1px,color:#7f1d1d

    subgraph OUTER ["OUTER FLYWHEEL — OS Self-Improvement (os-improvement-loop)"]
        direction TB
        O1["1. Orientation<BR>Read ledger, registry, last survey<BR>Know what to improve next"]:::outerNode
        O2["2. Document Test Scenario<BR>Write hypothesis + AC to tests/<BR>BEFORE emitting task.assigned"]:::outerNode
        O3["3. Assign to INNER_AGENT<BR>Emit task.assigned with strategy packet<BR>INNER_AGENT executes the work"]:::outerNode
        O4{"KEEP or DISCARD?<BR>Both eval gates ≥ baseline?"}:::gateNode
        O5a["5a. KEEP → Apply change<BR>Update canonical skill or artifact<BR>ORCHESTRATOR owns git"]:::outerNode
        O5b["5b. DISCARD → Correction packet<BR>Write correction-CID.md<BR>Re-assign to INNER_AGENT"]:::outerNode
        O6["6. Loop Close (all 4 mandatory)<BR>6a: ledger + registry row<BR>6b: surveys (all agents)<BR>6c: metrics + report<BR>6d: log M/L issues as tasks"]:::outerNode
        O7["7. Trigger Check<BR>3+ same-type friction → flag os-learning-loop<BR>North star regressing → emit immediately"]:::outerNode

        O1 --> O2 --> O3 --> O4
        O4 -->|KEEP| O5a
        O4 -->|DISCARD| O5b
        O5a --> O6
        O5b -->|re-cycle| O3
        O6 --> O7
        O7 -->|next session| O1
    end

    subgraph INNER ["INNER FLYWHEEL — Skill Improvement (os-eval-runner + os-skill-improvement)"]
        direction TB
        I1["os-eval-lab-setup<BR>Bootstrap lab repo with hard-copy plugin files<BR>Install eval engine, generate eval-instructions.md"]:::innerNode
        I2["os-eval-runner<BR>Phase 0 intake → confirm target + metrics<BR>Run evaluate.py --baseline (record baseline score)"]:::innerNode
        I3["INNER_AGENT executes work<BR>Mutate SKILL.md description, examples, triggers<BR>Emit friction events during uncertainty"]:::innerNode
        I4["eval_runner.py scores the patch<BR>PEER_AGENT runs independently<BR>KEEP if accuracy AND F1 ≥ baseline"]:::evalNode
        I5a["KEEP → Commit patch<BR>Update lab repo HEAD<BR>Backport via os-eval-backport"]:::innerNode
        I5b["DISCARD → New hypothesis<BR>os-skill-improvement RED-GREEN-REFACTOR<BR>Try different description angle"]:::innerNode
        I6["os-eval-backport<BR>Review lab diff<BR>Apply approved changes to master plugin source"]:::memNode

        I1 --> I2 --> I3 --> I4
        I4 -->|KEEP| I5a
        I4 -->|DISCARD| I5b
        I5b -->|iterate| I3
        I5a --> I6
    end

    %% Cross-flywheel relationships
    O3 -->|"spawns INNER work<BR>(strategy packet)"| I3
    I4 -->|"eval.result → PEER_AGENT<BR>KEEP/DISCARD verdict"| O4
    I6 -->|"backport triggers<BR>phase 6+7 close"| O6

    subgraph Legend ["Scope Distinction"]
        direction LR
        L1["OUTER asks:<BR>'Is the OS improvement<BR>process itself working?'"]:::outerNode
        L2["INNER asks:<BR>'Does this specific skill<BR>route and execute correctly?'"]:::innerNode
        L1 ~~~ L2
    end
