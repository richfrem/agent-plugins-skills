sequenceDiagram
    actor Human

    box rgba(200, 200, 200, 0.2) 1. Goal & Boundaries
        participant Spec as references/program.md<br/>(Karpathy: program.md)
    end

    box rgba(100, 150, 255, 0.15) 2. Execution & Agency
        participant Agent as Claude Agent<br/>(Karpathy: implied loop — agent IS the orchestrator)
    end

    box rgba(255, 200, 100, 0.15) 3. Mutable Target
        participant Target as SKILL.md<br/>(Karpathy: train.py)
    end

    box rgba(255, 100, 100, 0.1) 4. Scoring & Gatekeeping
        participant Grader as eval_runner.py<br/>(Karpathy: prepare.py — metric producer)
        participant Gate as evaluate.py<br/>(Karpathy: prepare.py — loop gate)
        participant Tests as evals/evals.json<br/>(Karpathy: test inputs)
    end

    box rgba(200, 200, 200, 0.2) 5. State & Memory
        participant Ledger as target-skill/evals/results.tsv<br/>(Karpathy: results.tsv — owned by target skill)
        participant Git as Git Version Control
    end

    Human->>Agent: "Run the autoresearch loop on target-skill"

    Agent->>Spec: read program.md (goal + locked files + NEVER STOP)
    Agent->>Target: read current SKILL.md
    Agent->>Ledger: read recent rows (scoring history)

    loop NEVER STOP

        Agent->>Target: make one focused change to SKILL.md

        Agent->>Gate: python evaluate.py --skill path/to/SKILL.md --desc "what changed"

        Gate->>Grader: eval_runner.py --skill SKILL.md --json
        Grader->>Target: read SKILL.md frontmatter keywords
        Grader->>Tests: read evals.json test prompts
        Grader-->>Gate: {"quality_score", "accuracy", "f1", "heuristic"}

        Gate->>Ledger: read last BASELINE row (score + f1)
        Gate->>Git: git rev-parse --short HEAD
        Gate->>Ledger: append row (timestamp, commit, score, baseline, accuracy, heuristic, f1, status, desc)

        alt KEEP (score >= baseline AND f1 >= baseline_f1)
            Gate-->>Agent: exit 0
            Agent->>Git: git add SKILL.md
            Agent->>Git: git commit "keep: score=X description"
        else DISCARD (score or f1 dropped)
            Gate-->>Agent: exit 1
            Agent->>Git: git checkout -- SKILL.md
        end

    end
