sequenceDiagram
    actor Human
    participant Agent as Claude Agent (loop orchestrator)
    participant ProgramMD as references/program.md
    participant TargetSkill as <target-skill>/SKILL.md
    participant EvaluatePY as scripts/evaluate.py (locked)
    participant EvalRunnerPY as scripts/eval_runner.py (locked)
    participant TargetEvals as <target-skill>/evals/evals.json (locked)
    participant TargetLog as <target-skill>/evals/results.tsv
    participant Git

    Human->>Agent: "Run the autoresearch loop on <target-skill>"

    Agent->>ProgramMD: read program.md (goal + locked files + NEVER STOP)
    Agent->>TargetSkill: read current SKILL.md
    Agent->>TargetLog: read recent rows (scoring history)

    loop NEVER STOP

        Agent->>TargetSkill: make one focused change to SKILL.md

        Agent->>EvaluatePY: python evaluate.py --skill <path> --desc "what changed"

        EvaluatePY->>EvalRunnerPY: eval_runner.py --skill SKILL.md --json
        EvalRunnerPY->>TargetSkill: read SKILL.md frontmatter keywords
        EvalRunnerPY->>TargetEvals: read evals.json test prompts
        EvalRunnerPY-->>EvaluatePY: {"quality_score": N, "accuracy": N, "f1": N, "heuristic": N}

        EvaluatePY->>TargetLog: read last BASELINE row (score + f1)
        EvaluatePY->>Git: git rev-parse --short HEAD (commit hash)
        EvaluatePY->>TargetLog: append row (timestamp, commit, score, baseline, accuracy, heuristic, f1, status, description)

        alt KEEP (score >= baseline AND f1 >= baseline_f1)
            EvaluatePY-->>Agent: exit 0
            Agent->>Git: git add <target-skill>/SKILL.md
            Agent->>Git: git commit "keep: score=X <description>"
        else DISCARD (score degraded or f1 dropped)
            EvaluatePY-->>Agent: exit 1
            Agent->>Git: git checkout -- <target-skill>/SKILL.md
        end

    end
