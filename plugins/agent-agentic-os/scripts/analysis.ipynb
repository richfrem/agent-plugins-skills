{
    "cells": [
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "# Agentic OS Loop Improvement Analysis\n",
                "\n",
                "Interactive analysis of eval score progression across loop cycles.\n",
                "Data source: `results.tsv` per skill (same format as autoresearch).\n",
                "\n",
                "Run `generate_report.py` first, or use this notebook for interactive exploration."
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "import pandas as pd\n",
                "import matplotlib.pyplot as plt\n",
                "from pathlib import Path\n",
                "\n",
                "# Point at the agent-agentic-os plugin root\n",
                "PLUGIN_DIR = Path(\"../../..\")  # relative to scripts/\n",
                "# Override if running from a different location:\n",
                "# PLUGIN_DIR = Path(\"/path/to/.agents/skills\")\n",
                "\n",
                "# Find all non-empty results.tsv files\n",
                "tsvs = {p.parent.parent.name: p\n",
                "        for p in PLUGIN_DIR.glob(\"skills/*/evals/results.tsv\")\n",
                "        if p.stat().st_size > 0}\n",
                "\n",
                "print(f\"Found {len(tsvs)} skill(s) with results:\")\n",
                "for name, path in tsvs.items():\n",
                "    print(f\"  {name}: {path}\")"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "def load_tsv(path: Path, skill_name: str) -> pd.DataFrame:\n",
                "    df = pd.read_csv(path, sep=\"\\t\", dtype=str)\n",
                "    df.columns = [c.strip().lower().replace(\" \", \"_\") for c in df.columns]\n",
                "    for alias in (\"val_bpb\", \"eval_score\"):\n",
                "        if alias in df.columns and \"score\" not in df.columns:\n",
                "            df = df.rename(columns={alias: \"score\"})\n",
                "    for alias in (\"description\", \"change\", \"summary\"):\n",
                "        if alias in df.columns and \"change_summary\" not in df.columns:\n",
                "            df = df.rename(columns={alias: \"change_summary\"})\n",
                "    if \"score\" in df.columns:\n",
                "        df[\"score\"] = pd.to_numeric(df[\"score\"], errors=\"coerce\")\n",
                "    if \"status\" in df.columns:\n",
                "        df[\"status\"] = df[\"status\"].str.strip().str.upper()\n",
                "    df[\"skill\"] = skill_name\n",
                "    return df\n",
                "\n",
                "frames = {name: load_tsv(path, name) for name, path in tsvs.items()}\n",
                "\n",
                "# Show first skill\n",
                "if frames:\n",
                "    first = list(frames.values())[0]\n",
                "    print(f\"Columns: {list(first.columns)}\")\n",
                "    display(first.head(10))"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Summary: outcomes per skill\n",
                "for skill, df in frames.items():\n",
                "    if \"status\" not in df.columns:\n",
                "        continue\n",
                "    counts = df[\"status\"].value_counts()\n",
                "    n_keep = counts.get(\"KEEP\", 0)\n",
                "    n_disc = counts.get(\"DISCARD\", 0)\n",
                "    n_decided = n_keep + n_disc\n",
                "    keep_rate = f\"{n_keep / n_decided:.0%}\" if n_decided > 0 else \"n/a\"\n",
                "    print(f\"{skill}: {len(df)} cycles  |  {n_keep} KEEP  |  {n_disc} DISCARD  |  keep rate {keep_rate}\")"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Progress chart — one subplot per skill (autoresearch style)\n",
                "\n",
                "KEEP_COLOR    = \"#2ecc71\"\n",
                "DISCARD_COLOR = \"#cccccc\"\n",
                "LINE_COLOR    = \"#27ae60\"\n",
                "\n",
                "n_skills = len(frames)\n",
                "if n_skills == 0:\n",
                "    print(\"No data yet. Run eval cycles to populate results.tsv.\")\n",
                "else:\n",
                "    fig, axes = plt.subplots(n_skills, 1, figsize=(16, 6 * n_skills))\n",
                "    if n_skills == 1:\n",
                "        axes = [axes]\n",
                "\n",
                "    for ax, (skill, df) in zip(axes, sorted(frames.items())):\n",
                "        df = df.reset_index(drop=True)\n",
                "        kept = df[df[\"status\"] == \"KEEP\"]\n",
                "        disc = df[df[\"status\"] == \"DISCARD\"]\n",
                "\n",
                "        if not disc.empty:\n",
                "            ax.scatter(disc.index.tolist(), disc[\"score\"].tolist(),\n",
                "                       c=DISCARD_COLOR, s=12, alpha=0.5, zorder=2, label=\"Discarded\")\n",
                "\n",
                "        if not kept.empty:\n",
                "            ax.scatter(kept.index.tolist(), kept[\"score\"].tolist(),\n",
                "                       c=KEEP_COLOR, s=55, zorder=4,\n",
                "                       edgecolors=\"black\", linewidths=0.5, label=\"Kept\")\n",
                "\n",
                "            scores = kept[\"score\"].tolist()\n",
                "            running_best = [max(scores[: i + 1]) for i in range(len(scores))]\n",
                "            ax.step(kept.index.tolist(), running_best, where=\"post\",\n",
                "                    color=LINE_COLOR, linewidth=2.0, alpha=0.75, zorder=3,\n",
                "                    label=\"Running best\")\n",
                "\n",
                "            for idx, row in kept.iterrows():\n",
                "                desc = str(row.get(\"change_summary\", \"\")).strip()\n",
                "                if len(desc) > 50:\n",
                "                    desc = desc[:47] + \"...\"\n",
                "                if desc:\n",
                "                    ax.annotate(desc, (idx, row[\"score\"]),\n",
                "                                textcoords=\"offset points\",\n",
                "                                xytext=(6, 6), fontsize=8,\n",
                "                                color=\"#1a7a3a\", rotation=28,\n",
                "                                ha=\"left\", va=\"bottom\")\n",
                "\n",
                "        n_keep = len(kept)\n",
                "        n_disc = len(disc)\n",
                "        ax.set_title(f\"{skill}   ({len(df)} cycles  |  {n_keep} kept)\", fontsize=11)\n",
                "        ax.set_xlabel(\"Cycle #\", fontsize=9)\n",
                "        ax.set_ylabel(\"Eval Score (higher = better)\", fontsize=9)\n",
                "        ax.legend(loc=\"lower right\", fontsize=8)\n",
                "        ax.grid(True, alpha=0.2)\n",
                "\n",
                "    plt.tight_layout()\n",
                "    plt.savefig(\"progress.png\", dpi=150, bbox_inches=\"tight\")\n",
                "    plt.show()\n",
                "    print(\"Saved to progress.png\")"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Top hits — sorted by improvement delta (like autoresearch)\n",
                "for skill, df in sorted(frames.items()):\n",
                "    kept = df[df[\"status\"] == \"KEEP\"].copy() if \"status\" in df.columns else pd.DataFrame()\n",
                "    if kept.empty or \"score\" not in kept.columns:\n",
                "        continue\n",
                "    baseline = df[\"score\"].dropna().iloc[0] if not df[\"score\"].dropna().empty else 0\n",
                "    kept[\"prev\"] = kept[\"score\"].shift(1).fillna(baseline)\n",
                "    kept[\"delta\"] = kept[\"score\"] - kept[\"prev\"]\n",
                "    hits = kept.sort_values(by=\"delta\", ascending=False)  # type: ignore[call-overload]\n",
                "\n",
                "    print(f\"\\n{skill} — Top improvements:\")\n",
                "    print(f\"  Baseline: {baseline:.4f}  Best: {kept['score'].max():.4f}\")\n",
                "    print(f\"  {'Delta':>8}  {'Score':>8}  Change\")\n",
                "    print(\"  \" + \"-\" * 60)\n",
                "    for _, row in hits.iterrows():\n",
                "        d = float(row.get(\"delta\") or 0)\n",
                "        s = float(row.get(\"score\") or 0)\n",
                "        desc = str(row.get(\"change_summary\", \"\")).strip()\n",
                "        print(f\"  {d:+.4f}   {s:.4f}  {desc}\")"
            ]
        }
    ],
