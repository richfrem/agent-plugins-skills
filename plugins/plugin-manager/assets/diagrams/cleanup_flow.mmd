flowchart TD
    %% Plugin Maintenance: Sync Flow

    subgraph Inputs
        LocalDir["./plugins/ Directory"]
        SourceFile["plugin-sources.json<BR>(GitHub sources config)"]
    end

    Start(["maintain-plugins: Sync"])
    CheckVendor{"plugin-sources.json<BR>Exists?"}

    LoadVendor["Load GitHub Source List<BR>(Source of Truth)"]
    SafeMode["Safety Mode<BR>(No cleanup — skip delete step)"]

    ScanLocal["Scan Local ./plugins/"]

    Compare{"Compare:<BR>GitHub Source vs Local"}

    subgraph States ["Three Plugin States"]
        Active["In BOTH Source + Local<BR>= Active Vendor Plugin"]
        Private["In Local ONLY<BR>= Project-Specific (Protected)"]
        Deleted["In Source ONLY<BR>= User Deleted"]
    end

    subgraph Actions
        Update["UPDATE<BR>Run sync_with_inventory.py<BR>(deploy to .agents/, .claude/)"]
        Protect["PROTECT<BR>Skip — never delete custom plugins"]
        Cleanup["CLEANUP<BR>Remove orphaned artifacts<BR>from .agents/skills/, .agents/workflows/<BR>.agents/rules/, .agents/hooks/, .claude/"]
    end

    Report["Generate local-plugins-inventory.json"]
    EndNode(["Sync Complete"])

    %% Connections
    Start --> CheckVendor
    CheckVendor -->|"Yes"| LoadVendor
    CheckVendor -->|"No"| SafeMode
    SafeMode --> ScanLocal
    LoadVendor --> ScanLocal
    ScanLocal --> Compare

    Compare -->|"In Source + Local"| Active
    Compare -->|"Local only"| Private
    Compare -->|"Source only"| Deleted

    Active --> Update
    Private --> Protect
    Deleted --> Cleanup
    Protect --> Update

    Update --> Report
    Cleanup --> Report
    Report --> EndNode

    SourceFile -.->|"declares sources"| CheckVendor
    LocalDir -..-|"scanned"| ScanLocal

    %% Styles
    classDef file fill:#eee,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    classDef action fill:#bbf,stroke:#333,stroke-width:2px
    classDef danger fill:#fbb,stroke:#333,stroke-width:2px
    classDef safe fill:#bfb,stroke:#333,stroke-width:2px

    class SourceFile,LocalDir file
    class Cleanup danger
    class Protect safe
    class Update action
