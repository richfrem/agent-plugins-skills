flowchart TD
    %% Plugin Sync & Cleanup Flow

    subgraph Inputs
        PSJ["plugin-sources.json\n(authoritative registry)"]
        LocalDir["plugins/ Directory\n(local source plugins only)"]
    end

    Start(["sync_with_inventory.py"])
    ReadRegistry["Read plugin-sources.json\nGet all registered plugin names"]

    ScanLocal["Scan local plugins/ Directory\n(for locally-sourced plugins)"]

    Compare{"Compare:\nRegistry vs Local plugins/"}

    subgraph States ["Plugin States"]
        Active["In Registry + Local\n= Active Local Plugin"]
        GitHubOnly["In Registry (GitHub source)\n= Remotely managed"]
        Stale["In Registry, missing locally\n= Stale / Removed"]
        Private["In Local ONLY\n= Project-Specific (Protected)"]
    end

    subgraph Actions
        Reinstall["REINSTALL\nRun plugin_installer.py\n(redeploy to .agents/, .claude/)"]
        Protect["PROTECT\nSkip — never delete custom plugins"]
        Cleanup["CLEANUP\nRemove orphaned artifacts\nfrom .agents/skills/, .agents/workflows/\n.agents/rules/, .agents/hooks/, .claude/"]
        Skip["SKIP\nGitHub plugins synced via plugin_add.py\nnot reinstalled automatically here"]
    end

    Report["Save local-plugins-inventory.json"]
    EndNode(["Sync Complete"])

    %% Connections
    Start --> ReadRegistry
    ReadRegistry --> ScanLocal
    ScanLocal --> Compare

    Compare -->|"Registry + Local"| Active
    Compare -->|"Registry (GitHub source)"| GitHubOnly
    Compare -->|"Registry, no local dir"| Stale
    Compare -->|"Local only"| Private

    Active --> Reinstall
    GitHubOnly --> Skip
    Stale --> Cleanup
    Private --> Protect

    Reinstall --> Report
    Skip --> Report
    Cleanup --> Report
    Protect --> Report
    Report --> EndNode

    PSJ -.->|"source of truth"| ReadRegistry
    LocalDir -.->|"scanned"| ScanLocal

    %% Styles
    classDef file fill:#eee,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    classDef action fill:#bbf,stroke:#333,stroke-width:2px
    classDef danger fill:#fbb,stroke:#333,stroke-width:2px
    classDef safe fill:#bfb,stroke:#333,stroke-width:2px
    classDef skip fill:#ffe,stroke:#aa8,stroke-width:1px

    class PSJ,LocalDir file
    class Cleanup danger
    class Protect,Skip safe
    class Reinstall action
