flowchart TD
    Start(("Exploration Trigger<BR>──────────────<BR>idea / need / problem<BR>issue / question<BR>──────────────<BR>source: organic discovery<BR>OR spec-kitty re-entry")) --> IntakeOpen

    subgraph Phase0["Phase 0: Intake Interview (intake-agent)"]
        direction TB
        IntakeOpen["Open question:<BR>'Describe what brought you here'"]
        IntakeClassify["Clarifying questions:<BR>domain · nature · prior context<BR>desired output · timebox"]
        IntakeConfirm{{"Confirm classification:<BR>domain / type / output<BR>correct? yes / adjust"}}
        IntakeDraft["Pre-fill session-brief.md<BR>from intake answers<BR>[INTAKE DRAFT — confirm] for gaps"]
        IntakeOpen --> IntakeClassify --> IntakeConfirm
        IntakeConfirm -->|Adjust| IntakeClassify
        IntakeConfirm -->|Confirmed| IntakeDraft
    end

    IntakeDraft --> Brief["Review & confirm<BR>exploration/session-brief.md"]
    Brief --> BriefType{Exploration Type}
    BriefType -->|greenfield| HumanGate0
    BriefType -->|brownfield| Brownfield["Add / verify Current System<BR>Behavior section"]
    BriefType -->|re-entry spike| ReEntry["Verify engineering<BR>blocking question"]
    Brownfield --> HumanGate0
    ReEntry --> HumanGate0

    HumanGate0{{"Human Gate 0<BR>Brief is clear?<BR>Proceed / Refine"}}
    HumanGate0 -->|Refine| IntakeClassify
    HumanGate0 -->|Proceed| Pass1

    subgraph CaptureLoop["Phase 1: Requirements Capture (Dual-Loop-inspired CLI pass chain)"]
        direction TB
        Pass1["Pass 1: Problem Framing<BR>requirements-doc-agent CLI<BR>→ captures/problem-framing.md"]
        OrchCheck1{{"Orchestrator check<BR>review problem-framing.md<BR>stop if > 3 gaps"}}
        Pass2["Pass 2: Business Requirements<BR>requirements-doc-agent CLI<BR>→ captures/brd-draft.md"]
        Pass3["Pass 3: User Stories<BR>requirements-doc-agent CLI<BR>→ captures/user-stories-draft.md"]
        Pass4["Pass 4: Issues & Opportunities<BR>requirements-doc-agent CLI<BR>→ captures/issues-opportunities.md"]
        RepeatCheck["Same lightweight orchestrator check<BR>repeats after Pass 2 and Pass 3"]
        Pass1 --> OrchCheck1 --> Pass2 --> Pass3 --> Pass4
    end

    OrchCheck1 -->|"Too many gaps"| Brief
    RepeatCheck -.-> Pass3

    Pass4 --> HumanGate1{{"Human Gate 1<BR>Review captures<BR>and pass-chain quality"}}
    HumanGate1 -->|"Too many gaps in any pass<BR>(> 3 per doc)"| Brief
    HumanGate1 -->|"Acceptable"| ProtoQ{Prototype session<BR>needed?}

    subgraph Phase2["Phase 2: Prototype Session (Optional)"]
        direction TB
        ProtoGen["prototype-builder skill:<BR>Generate prototype"]
        ProtoObs["prototype-companion-agent CLI:<BR>→ captures/prototype-notes.md"]
        ProtoGen --> ProtoObs
    end

    ProtoQ -->|Yes| ProtoGen
    ProtoQ -->|No| NarrowGate
    ProtoObs --> NarrowGate

    NarrowGate{{"Narrowing Gate<BR>Evidence filled for<BR>all 5 readiness checks?"}}
    NarrowGate -->|"Not ready<BR>run spike"| Pass1
    NarrowGate -->|"Ready"| HandoffPrep

    subgraph Phase3["Phase 3: Handoff Preparation"]
        direction TB
        HandoffPrep["handoff-preparer-agent CLI:<BR>Synthesize all captures<BR>→ handoff/exploration-handoff.md"]
        HandoffReview["Review against<BR>exploration-handoff-template<BR>(check evidence fields)"]
        HandoffPrep --> HandoffReview
    end

    HandoffReview --> OptBridge{{"Optional:<BR>Engineering harness<BR>present?"}}
    OptBridge -->|"No — standalone<BR>exploration"| NextStep
    OptBridge -->|"Yes — double diamond<BR>integration"| SpecDraft

    subgraph Phase5["Phase 5 OPTIONAL: Planning Draft — Engineering Harness Integration"]
        direction TB
        SpecDraft["planning-doc-agent CLI<BR>Mode: spec-draft<BR>→ planning-drafts/spec-draft.md"]
        PlanDraft["planning-doc-agent CLI<BR>Mode: plan-draft<BR>→ planning-drafts/plan-draft.md"]
        TasksOutline["planning-doc-agent CLI<BR>Mode: tasks-outline<BR>→ planning-drafts/tasks-outline.md"]
        HumanGate2{{"Human Gate 2<BR>Review staging drafts<BR>[NEEDS HUMAN INPUT] gaps?"}}
        SpecDraft --> PlanDraft --> TasksOutline --> HumanGate2
    end

    HumanGate2 --> NextStep

    NextStep{{"Recommended<BR>Next Step"}}
    NextStep -->|Spec ready| FormalSpec["Generate formal spec<BR>via engineering agent<BR>(uses approved staging drafts)"]
    NextStep -->|Needs more| Spike["Targeted exploration<BR>spike"]
    NextStep -->|Defer| Roadmap["Update roadmap<BR>and defer"]

    Spike --> Pass1
    FormalSpec --> EngineeringCycle["Execution Sandbox<BR>Engineering Cycle"]
    EngineeringCycle --> ReEntryQ{{"Unresolved<BR>ambiguity found?"}}
    ReEntryQ -->|No| Done(["Done"])
    ReEntryQ -->|"Yes — harness present"| ReEntryBrief["planning-doc-agent CLI<BR>Mode: re-entry-scope<BR>→ session-brief-reentry.md"]
    ReEntryQ -->|"Yes — standalone"| ReEntryIntake["Run intake-agent again<BR>classify as re-entry spike<BR>→ session-brief.md"]
    ReEntryBrief --> Start
    ReEntryIntake --> Start

    Baseline["◆ Baseline: 3 sessions<BR>log to evals/results.tsv"] -.->|"Phase D optimizer<BR>once baseline stable"| Pass4

    classDef phase fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef gate fill:#ffebee,stroke:#c62828,stroke-width:3px,color:#b71c1c
    classDef agent fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef output fill:#fff3e0,stroke:#ef6c00,stroke-width:2px
    classDef ref fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1px,stroke-dasharray:5

    class Phase0,CaptureLoop,Phase2,Phase3,Phase5 phase
    class HumanGate0,HumanGate1,NarrowGate,OptBridge,NextStep,ReEntryQ,IntakeConfirm,OrchCheck1 gate
    class Pass1,Pass2,Pass3,Pass4,ProtoGen,ProtoObs,HandoffPrep,SpecDraft,PlanDraft,TasksOutline,IntakeOpen,IntakeClassify,IntakeDraft agent
    class FormalSpec,Spike,Roadmap,Done output
    class Baseline,RepeatCheck ref
