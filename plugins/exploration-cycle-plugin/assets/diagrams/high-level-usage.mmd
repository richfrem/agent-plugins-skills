    direction TB
        IA[["intake-agent<BR>─────────────────────────<BR>Front-door interviewer<BR>Runs before exploration-workflow<BR>Pre-fills exploration/session-brief.md<BR>High-touch · primary model"]]
        ECO[["exploration-cycle-orchestrator-agent<BR>─────────────────────────<BR>Alternative Phase A orchestrator<BR>Dispatches requirements-doc-agent via CLI<BR>Greenfield · brownfield · re-entry spikes"]]
  end
 subgraph Core["Orchestration Layer"]
    direction TB
        OW["⚙️ exploration-workflow<BR>State Machine Orchestrator<BR>─────────────────────────<BR>① Read dashboard state<BR>② Orientation summary<BR>③ Route to active phase<BR>④ Invoke child skill<BR>⑤ HARD-GATE approval<BR>⑥ Write dashboard · advance"]
        DB["📋 exploration-dashboard.md<BR>─────────────────────────<BR>- [x] Phase 1 ✅<BR>- [x] Phase 2 ✅<BR>- [ ] Phase 3 🔵 Active<BR>- [ ] Phase 4<BR>─────────────────────────<BR>Session state · no server · no DB"]
  end
 subgraph P1Box["Phase 1 — Problem Framing"]
        DP["🔍 discovery-planning (Skill)<BR>─────────────────────────<BR>5 questions · one at a time<BR>Written Discovery Plan<BR>Iterative until SME says YES<BR>→ exploration/discovery-plans/"]
        DPA[["discovery-planning-agent<BR>(Interactive agent dispatch path)"]]
  end
 subgraph P2Box["Phase 2 — Visual Blueprinting"]
        VC["🎨 visual-companion (Skill)<BR>─────────────────────────<BR>Option A · single page overview<BR>Option B · step-by-step flow<BR>Option C · two-panel layout<BR>Adapted to Discovery Plan context<BR>→ exploration/captures/layout-direction.md"]
  end
 subgraph P3Box["Phase 3 — Prototyping"]
        PB["🏗️ prototype-builder (Skill)<BR>Phase orchestrator<BR>Coordinates subagent build loop"]
        SP["⚙️ subagent-driven-prototyping<BR>─────────────────────────<BR>3–6 named components<BR>Fresh agent per component<BR>Self-review vs Discovery Plan<BR>BLOCKED · NEEDS_CONTEXT gates<BR>→ exploration/prototype/index.html"]
        PBA[["prototype-builder-agent<BR>(Alternate dispatch path)"]]
  end
 subgraph Stage0["Stage 0 Scribes (auto-run before synthesis)"]
    direction LR
        BRC["business-requirements-capture"]
        USC["user-story-capture"]
        BWD["business-workflow-doc<BR>(conditional: only if process flow)"]
  end
 subgraph P4Box["Phase 4 — Handoff & Specs"]
        EH["📦 exploration-handoff (Skill)<BR>─────────────────────────<BR>Stage 0: auto-runs scribe skills<BR>Tier Assessment (SME classifies)<BR>Reader Test: predicts 3 downstream Qs<BR>→ handoff-package.md"]
        HPA[["handoff-preparer-agent<BR>(Alternate CLI dispatch path)"]]
        Stage0
  end
 subgraph Phases["4-Phase Execution Pipeline"]
    direction TB
        P1Box
        P2Box
        P3Box
        P4Box
  end
 subgraph Patterns["Key Patterns (adapted from obra/superpowers · MIT)"]
    direction TB
        HG["HARD-GATE<BR>(No build until SME YES)"]
        DI["Dashboard Intercept<BR>(Skills redirect to orchestrator<BR>if active session detected)"]
        BSA["Blank-slate Subagents<BR>(Zero prior context per component)"]
  end
 subgraph Plugin["exploration-cycle-plugin  ·  installable via uvx"]
    direction LR
        PreSession
        Core
        Phases
        Patterns
  end
