flowchart TD
    subgraph Source ["Source"]
        Plugins["plugins/<br/>(any plugin, Open Standards format)"]
    end

    subgraph Bridge ["agent-bridge"]
        BI["bridge_installer.py<br/>(format translator + patcher)"]
    end

    subgraph Agents ["Target Agent Environments"]
        Antigravity[".agent/<br/>Antigravity"]
        Copilot[".github/<br/>GitHub Copilot"]
        Claude[".claude/<br/>Claude Code"]
        Gemini[".gemini/<br/>Gemini CLI"]
        Windsurf[".windsurf/<br/>Windsurf IDE"]
    end

    %% Flows
    Plugins -->|"Load skills + commands"| BI

    BI -->|"Deploy workflows + rules"| Antigravity
    BI -->|"Deploy prompt files"| Copilot
    BI -->|"Deploy commands"| Claude
    BI -->|"Deploy TOML + commands"| Gemini
    BI -->|"Deploy workflow files"| Windsurf

    classDef source fill:#eee,stroke:#333,stroke-width:1px
    classDef bridge fill:#bbf,stroke:#333,stroke-width:2px
    classDef agent fill:#bfb,stroke:#333,stroke-width:1px

    class Plugins source
    class BI bridge
    class Antigravity,Copilot,Claude,Gemini,Windsurf agent
