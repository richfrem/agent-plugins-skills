flowchart TD
    subgraph Boot["Session Start (Boot)"]
        B1["1. Load primer_file\n(Role / Identity / Constraints)"]
        B2["2. Load boot_contract_file\n(Immutable Constraints)"]
        B3["3. Load boot_digest_file\n(Active Tasks / Status)"]
        B4["4. Load snapshot_file\n(Cognitive Hologram)"]
        B5{"Snapshot\ncurrent?"}
        B1 --> B2 --> B3 --> B4 --> B5
        B5 -->|"Yes"| READY["Agent Ready"]
        B5 -->|"Stale"| FLAG["Flag for refresh\nat session end"]
        FLAG --> READY
    end

    subgraph Session["During Session"]
        READY --> EV{"Event type?"}
        EV -->|"New learning"| NL["Write to domain_data_dir/{topic}/"]
        EV -->|"New decision"| ND["Create design_docs_dir/{id}_{name}.md"]
        EV -->|"New tool"| NT["Register in tool inventory\n(rlm-factory inject_summary.py)"]
        EV -->|"Correction"| NC["Update file + disputes log"]
        EV -->|"Code search"| NS["3-Phase Search:\n1. query_cache.py (rlm-search)\n2. query.py (vector-db-agent)\n3. rg / grep"]
        NL & ND & NT & NC & NS --> EV
    end

    subgraph Seal["Session End (Seal)"]
        S1["1. Update snapshot_file\n(add new 1-sentence entries)"]
        S2["2. Validate no drift\n(integrity check)"]
        S3{"External traces\nconfigured?"}
        S4["3. Persist to traces_file\n(e.g. HuggingFace dataset)"]
        S5["Session Sealed"]
        S1 --> S2 --> S3
        S3 -->|"Yes"| S4 --> S5
        S3 -->|"No"| S5
    end

    EV -->|"Session ends"| Seal

    style Boot fill:#4CAF50,color:#fff
    style Session fill:#2196F3,color:#fff
    style Seal fill:#FF9800,color:#fff
    style READY fill:#607D8B,color:#fff
    style S5 fill:#607D8B,color:#fff
